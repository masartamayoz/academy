rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitives & Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    // Performance-optimized admin check using email
    function isFastAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'academy.masartamayoz@gmail.com' ||
        request.auth.token.email == 'masartamayoz@gmail.com' ||
        request.auth.token.email == 'centrekhawarizmi2020@gmail.com' ||
        request.auth.token.email == 'admin@admin.com'
      );
    }

    function isAdmin() {
      return isFastAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', 'student') == 'admin');
    }

    function isTeacher() {
      return isFastAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', 'student') == 'teacher');
    }

    function isParent() {
      return isFastAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', 'student') == 'parent');
    }

    function isParentOf(childId) {
      return isSignedIn() && exists(/databases/$(database)/documents/parentChildren/$(request.auth.uid + '_' + childId));
    }

    function isMeSubscribed() {
      return isFastAdmin() || 
             (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', 'student') == 'admin') || 
             (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', 'student') == 'teacher') || 
             (isSignedIn() && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('subscriptionStatus', 'inactive') == 'active' && 
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('subscriptionExpiry', '') == '' || 
               request.time < timestamp.date(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('subscriptionExpiry', '2000-01-01T00:00:00Z'))));
    }

    function isChildSubscribed(childId) {
      return isParentOf(childId) && 
             get(/databases/$(database)/documents/users/$(childId)).data.get('subscriptionStatus', 'inactive') == 'active' && 
             (get(/databases/$(database)/documents/users/$(childId)).data.get('subscriptionExpiry', '') == '' || 
              request.time < timestamp.date(get(/databases/$(database)/documents/users/$(childId)).data.get('subscriptionExpiry', '2000-01-01T00:00:00Z')));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Collection Rules

    // Global Admin Escape Hatch
    match /{allCollections=**} {
      allow read, write: if isFastAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read, list: if true;
      allow create: if true;
      allow update: if isSignedIn() && (isFastAdmin() || isAdmin() || isOwner(userId));
      allow delete: if isFastAdmin() || isAdmin();
    }

    // Wallets
    match /wallets/{userId} {
      allow read, list: if isFastAdmin() || isAdmin() || isOwner(userId) || isParentOf(userId);
      allow write: if isFastAdmin() || isAdmin();
    }

    // Attendance Collection
    match /attendance/{attendanceId} {
      allow read, list: if isSignedIn() && (
        isFastAdmin() || 
        isAdmin() || 
        isTeacher() ||
        (isOwner(resource.data.userId) && isMeSubscribed()) || 
        (isParentOf(resource.data.userId) && isChildSubscribed(resource.data.userId))
      );
      allow create: if isSignedIn() && (isFastAdmin() || isAdmin() || isTeacher() || isMeSubscribed());
      allow update, delete: if isFastAdmin() || isAdmin();
    }

    // Groups Collection
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isFastAdmin() || isAdmin();
    }

    // Videos Collection
    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isFastAdmin() || isAdmin();
    }

    // Receipts Collection
    match /receipts/{receiptId} {
      allow read: if isFastAdmin() || isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.parentId == request.auth.uid));
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || incoming().parentId == request.auth.uid);
      allow update, delete: if isFastAdmin() || isAdmin();
    }

    // Payout Requests
    match /payoutRequests/{requestId} {
      allow read, list: if isFastAdmin() || isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isFastAdmin() || isAdmin();
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read, list: if isSignedIn() && (isFastAdmin() || isAdmin() || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isFastAdmin() || isAdmin() || (resource.data.recipientId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])));
      allow delete: if isFastAdmin() || isAdmin();
    }

    // Teacher Sessions
    match /teacherSessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() || isFastAdmin() || isAdmin();
      allow update: if isFastAdmin() || isAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
      allow delete: if isFastAdmin() || isAdmin();
    }

    // Parent-Child links
    match /parentChildren/{linkId} {
      allow read, list: if isSignedIn() && (isFastAdmin() || isAdmin() || resource.data.parentId == request.auth.uid || resource.data.childId == request.auth.uid);
      allow create: if isSignedIn() && (isFastAdmin() || isAdmin() || incoming().parentId == request.auth.uid);
      allow update: if isFastAdmin() || isAdmin() || (isSignedIn() && (existing().parentId == request.auth.uid || resource.data.parentId == request.auth.uid));
      allow delete: if isFastAdmin() || isAdmin() || (isSignedIn() && (existing().parentId == request.auth.uid || resource.data.parentId == request.auth.uid));
    }

    // Transactions Collection (Legacy/Supporting)
    match /transactions/{transactionId} {
      allow read: if isFastAdmin() || isAdmin() || (isSignedIn() && (resource.data.parentId == request.auth.uid || resource.data.userId == request.auth.uid));
      allow write: if isFastAdmin() || isAdmin();
    }

    // Content Access Rules Collection
    match /contentAccessRules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if isFastAdmin() || isAdmin();
    }

    // Connectivity Test
    match /test/connection {
      allow read: if true;
    }
  }
}
