{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "parent", "teacher", "admin"] },
        "level": { "type": "string" },
        "birthDate": { "type": "string" },
        "wilaya": { "type": "string" },
        "moughataa": { "type": "string" },
        "school": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "pending"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "userType"]
    },
    "Video": {
      "title": "Video",
      "description": "Educational video content",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["lesson", "exercise", "assignment", "synthesis"] },
        "level": { "type": "string" },
        "chapter": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Subscription payment receipt",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "parentId": { "type": "string" },
        "receiptURL": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Group": {
      "title": "Group",
      "description": "Study group/class",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "level": { "type": "string" },
        "teacherId": { "type": "string" },
        "meetLink": { "type": "string" },
        "whatsappLink": { "type": "string" }
      }
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Live session attendance log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userType": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "meetLink": { "type": "string" },
        "sessionId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "TeacherSession": {
      "title": "TeacherSession",
      "description": "Scheduled live session",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "level": { "type": "string" },
        "dateTime": { "type": "string" },
        "meetLink": { "type": "string" },
        "chapter": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User financial record",
      "type": "object",
      "properties": {
        "balance": { "type": "string" },
        "earnedTotal": { "type": "string" },
        "paid": { "type": "number" },
        "transactions": { "type": "array" }
      }
    },
    "PayoutRequest": {
      "title": "PayoutRequest",
      "description": "Teacher withdrawal request",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "System notification message",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Student/Parent/Teacher profiles" },
    "/videos/{videoId}": { "schema": "Video", "description": "Educational content" },
    "/receipts/{receiptId}": { "schema": "Receipt", "description": "Payment proofs" },
    "/groups/{groupId}": { "schema": "Group", "description": "Classroom groups" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance logs" },
    "/teacherSessions/{sessionId}": { "schema": "TeacherSession", "description": "Scheduled classes" },
    "/wallets/{userId}": { "schema": "Wallet", "description": "Financial records" },
    "/payoutRequests/{requestId}": { "schema": "PayoutRequest", "description": "Withdrawal requests" },
    "/messages/{messageId}": { "schema": "Message", "description": "System messages/notifications" }
  }
}
